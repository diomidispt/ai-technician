# Copy to .env for local dev. NEVER commit real secrets (.env is gitignored).
# In AWS, real config comes from env vars + Secrets Manager, not this file.

# --- Backend ---
# Comma-separated origins allowed to call the API (local Vite dev server).
CORS_ORIGINS=http://localhost:5173
# EU data residency (golden rule). No AWS calls in phase 1 — kept for later phases.
AWS_REGION=eu-central-1

# --- Data (Postgres + pgvector) ---
# Local venv default is localhost; docker-compose overrides host to the `postgres` service.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jensen

# --- Ollama (local LLM + embeddings; $0, on-device) ---
# Multilingual by default (answers in the user's language, incl. Greek).
# Local venv: localhost. In the backend container: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
ANSWER_MODEL=aya-expanse:8b     # multilingual; llama3.2:3b for faster English-only
EMBED_MODEL=bge-m3             # multilingual embeddings (cross-lingual retrieval)
EMBED_DIM=1024                # must match the embedding model (bge-m3 = 1024)

# --- Retrieval tuning ---
# RETRIEVAL_TOP_K=5
# SUFFICIENCY_MAX_DISTANCE=0.6
# RELEVANCE_MARGIN=0.1

# --- Auth (local simulation of Cognito) ---
JWT_SECRET=dev-only-change-me      # override in any shared/real deployment
# JWT_EXPIRE_MINUTES=480
# Seeded on startup if the users table is empty (demo logins):
SEED_ADMIN_EMAIL=admin
SEED_ADMIN_PASSWORD=admin
SEED_TECH_EMAIL=technician
SEED_TECH_PASSWORD=technician

# --- Web-search fallback (DuckDuckGo, no key). false = fully offline/private. ---
WEB_FALLBACK_ENABLED=true

# --- Later phases (not used yet) ---
# COGNITO_USER_POOL_ID=
# COGNITO_APP_CLIENT_ID=
